# Copy this file to .env.local and fill in your values.

# ── Firebase ──────────────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your apps → Web app

REACT_APP_FIREBASE_API_KEY=your_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Register free at https://razorpay.com → Dashboard → Settings → API Keys
# Use Test keys (rzp_test_...) during development, Live keys in production.

# RAZORPAY_KEY_ID            → used by local server.js / Vercel API functions / exposed to browser (public key only, safe)
# RAZORPAY_KEY_SECRET        → NEVER prefix with REACT_APP_ — backend only

RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE
